{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "settings": {
    "next": {
      "rootDir": ["apps/web"]
    }
  },
  "ignorePatterns": [
    "**/.agents/**",
    "**/dist/**",
    "**/.next/**",
    "**/out/**",
    "**/build/**",
    "**/next-env.d.ts"
  ],
  "overrides": [
    {
      "files": ["apps/web/**/*.{js,jsx,ts,tsx}"],
      "plugins": ["eslint", "typescript", "oxc", "unicorn", "react", "nextjs"],
      "env": {
        "browser": true
      },
      "rules": {
        "react/react-in-jsx-scope": "off"
      }
    },
    {
      "files": ["packages/ui/**/*.{js,jsx,ts,tsx}"],
      "plugins": ["eslint", "typescript", "oxc", "unicorn", "react"],
      "env": {
        "browser": true
      },
      "rules": {
        "react/react-in-jsx-scope": "off"
      }
    }
  ]
}
